{
  "name": "ask-amo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "concurrently \"vite build\" \"tsc -p tsconfig.server.json\"",
    "start": "node dist/server.js",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "build:analyze": "vite build --mode production",
    "cap:add:android": "npx cap add android",
    "cap:sync": "npm run build && npx cap sync",
    "cap:android": "npm run build && npx cap sync android && npx cap open android",
    "cap:wireless": "node redeploy-android.mjs",
    "cap:assets": "npx @capacitor/assets generate --assetPath assets --android --pwa --iconBackgroundColor \"#0A0A0A\" --iconBackgroundColorDark \"#0A0A0A\" --splashBackgroundColor \"#050505\" --splashBackgroundColorDark \"#050505\""
  },
  "dependencies": {
    "@capacitor/android": "^8.2.0",
    "@capacitor/app": "^8.0.1",
    "@capacitor/core": "^8.2.0",
    "@capacitor/haptics": "^8.0.1",
    "@capacitor/keyboard": "^8.0.1",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/status-bar": "^8.0.1",
    "@mlc-ai/web-llm": "^0.2.56",
    "@sqlite.org/sqlite-wasm": "^3.51.2-build7",
    "@types/pdfjs-dist": "^2.10.377",
    "@xenova/transformers": "^2.15.3",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/xterm": "^6.0.0",
    "autoprefixer": "^10.4.14",
    "clsx": "^2.0.0",
    "concurrently": "^8.2.2",
    "dotenv": "^16.3.1",
    "fuse.js": "^7.0.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.34.3",
    "onnxruntime-web": "^1.16.2",
    "pdfjs-dist": "^5.5.207",
    "tailwind-merge": "^2.2.0",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.7.0",
    "uuid": "^9.0.1",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/express": "^4.17.21",
    "@types/node": "^22.19.15",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@types/xterm": "^2.0.3",
    "@vitejs/plugin-react-swc": "^4.2.3",
    "@vitest/coverage-v8": "^4.1.0",
    "@vitest/ui": "^4.1.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "happy-dom": "^20.8.4",
    "rollup-plugin-visualizer": "^7.0.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.0"
  }
}
